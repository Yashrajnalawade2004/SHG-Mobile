# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000


GROQ_API_KEY=your_groq_api_key_here

# ─── Android APK / Native Build ──────────────────────────────────────────────
# Set this to your deployed backend URL before building the Android APK.
# Leave empty (or unset) for web — relative paths are used automatically.
# Must NOT have a trailing slash.
# Example (Replit deployment):
# EXPO_PUBLIC_API_URL=https://shg-records.replit.app
# Example (local LAN testing):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:5000
EXPO_PUBLIC_API_URL=
